# Copy this file to .env.local for local development.
# In Render, add the same keys in the service Environment tab or through render.yaml.
#
# Public build-time values. These are visible to browser users.
NEXT_PUBLIC_SITE_URL=https://landlsourdough.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Supabase server-side values. Keep these secret.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Admin access. Comma-separate multiple owner emails.
ADMIN_EMAILS=owner@example.com

# Stripe test mode. Use sk_test_* locally. Use the whsec_* printed by
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` for local webhooks.
# Leave blank to keep checkout in demo/fallback mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend email.
RESEND_API_KEY=
RESEND_FROM="Luna & Lorelai's Sourdough <orders@landlsourdough.com>"
BAKERY_EMAIL=orders@landlsourdough.com
OWNER_ALERTS_ENABLED=true
OWNER_ALERT_EMAIL=orders@landlsourdough.com
OWNER_ALERT_SMS_EMAIL=4703880184@vtext.com

# OpenAI. Leave OPENAI_API_KEY blank to use deterministic fallback replies/drafts.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Delivery fallback values. Admin delivery settings in Supabase override these for storefront reads.
# ZIP allowlist is a preliminary area check; full checkout pricing uses Google Routes drive time.
DELIVERY_CENTER_LAT=34.2368
DELIVERY_CENTER_LNG=-84.4908
DELIVERY_RADIUS_MILES=12
DELIVERY_FEE_CENTS=600
DELIVERY_ALLOWED_POSTAL_CODES=30114,30115,30107,30183,30188,30189
DELIVERY_SERVICE_AREA_COPY="Delivery is available in selected ZIP codes around Canton and Woodstock: 30114, 30115, 30107, 30183, 30188, and 30189."
GOOGLE_MAPS_API_KEY=
DELIVERY_ORIGIN_ADDRESS="4501 Holly Springs Parkway, Canton, GA 30115"
DELIVERY_ROUTE_END_ADDRESS="403 Three Branches Ct, Woodstock, GA 30188"
DELIVERY_MAX_DRIVE_MINUTES=30
DELIVERY_FEE_BANDS=0-10:500,11-20:700,21-30:1000
